# Sallon-ConnecT — .env.example
# ─────────────────────────────────────────────────────────────────
# Copier ce fichier en .env (jamais commité dans git)
# Renseigner uniquement les valeurs que vous souhaitez activer
# ─────────────────────────────────────────────────────────────────

# ── Serveur ──────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ── Réseau ───────────────────────────────────────────────────────
NETWORK_SCAN_ENABLED=false

# ── Appareils (hostnames ou IP locales) ──────────────────────────
# Convention : DEVICE_<ID_MAJUSCULE>_HOST=<hostname.local>
DEVICE_IA_ORDINATEUR_BOM_WXX9_HOST=nom-pc-huawei.local
DEVICE_TV_SAMSUNG_7_SERIES_HOST=samsung-tv.local
DEVICE_PC_BUREAU_HOST=pc-bureau.local
DEVICE_GALAXY_S23_ULTRA_HOST=galaxy-s23.local
DEVICE_BOX_SFR_FIBRE_HOST=livebox.home

# ── Galerie locale (Phase 4) ─────────────────────────────────────
# Activer et définir le chemin d'un dossier d'images autorisé
MEDIA_LOCAL_GALLERY_ENABLED=false
MEDIA_LOCAL_GALLERY_PATH=

# ── YouTube embed (Phase 4) ──────────────────────────────────────
# Embed public légal — aucune clé API requise
# Mettre false pour désactiver le champ YouTube dans l'interface
YOUTUBE_EMBED_ENABLED=true

# ── ADB — Galaxy S23 Ultra (Phase 6) ────────────────────────────
# Nécessite Android Platform Tools installé
# ADB_DEVICE_ID est facultatif — ne jamais mettre un vrai numéro de série
# ADB_READ_ONLY=true est obligatoire — ne jamais mettre false
# ADB_MASK_DEVICE_ID=true masque les IDs dans les réponses API et les logs
ADB_ENABLED=false
ADB_PATH=
ADB_DEVICE_ID=
ADB_READ_ONLY=true
ADB_COMMAND_TIMEOUT_MS=5000
ADB_MASK_DEVICE_ID=true

# ── DLNA / UPnP (Phase 7) ────────────────────────────────────────
# Découverte locale uniquement — aucun contrôle TV, aucun envoi de média
# DLNA_READ_ONLY=true obligatoire
# DLNA_MASK_LOCAL_IPS=true masque les IP locales dans les réponses
DLNA_ENABLED=false
DLNA_DISCOVERY_TIMEOUT_MS=3000
DLNA_MULTICAST_ADDRESS=239.255.255.250
DLNA_MULTICAST_PORT=1900
DLNA_READ_ONLY=true
DLNA_MAX_RESPONSES=30
DLNA_FETCH_DESCRIPTIONS=false
DLNA_MASK_LOCAL_IPS=true

# ── SmartThings Samsung TV (Phase 8) ─────────────────────────────
# Créer un Personal Access Token sur https://account.smartthings.com/tokens
# Scopes nécessaires en lecture seule : devices:read  locations:read  scenes:read
# SMARTTHINGS_READ_ONLY=true obligatoire — ne jamais mettre false
# SMARTTHINGS_ALLOW_SCENE_EXECUTION=false obligatoire dans cette phase
# Ne jamais commiter ce fichier avec un vrai token
SMARTTHINGS_ENABLED=false
SMARTTHINGS_TOKEN =
SMARTTHINGS_READ_ONLY=true
SMARTTHINGS_API_BASE_URL=https://api.smartthings.com/v1
SMARTTHINGS_TV_DEVICE_ID=
SMARTTHINGS_DEFAULT_LOCATION_ID=
SMARTTHINGS_COMMAND_TIMEOUT_MS=5000
SMARTTHINGS_MASK_IDS=true
SMARTTHINGS_ALLOW_SCENE_EXECUTION=false
SMARTTHINGS_SCENE_EXECUTION_REQUIRE_CONFIRMATION=true
SMARTTHINGS_SCENE_EXECUTION_CONFIRMATION_CODE=CONFIRMER
SMARTTHINGS_SCENE_ALLOWLIST=
SMARTTHINGS_SCENE_AUDIT_ENABLED=true
SMARTTHINGS_SCENE_AUDIT_PATH=runtime/smartthings-scene-audit.json
SMARTTHINGS_BLOCK_DEVICE_COMMANDS=true
SMARTTHINGS_BLOCK_SENSITIVE_DEVICES=true

# ── Commandes TV Samsung via SmartThings (Phase 10) ─────────────
# Commandes TV désactivées par défaut — opt-in explicite requis
# Ne jamais autoriser de TV non identifiée dans l'allowlist
# Ne jamais mettre SMARTTHINGS_TV_BLOCK_VOLUME_COMMANDS=false
# SMARTTHINGS_TV_DEVICE_ALLOWLIST : IDs réels des TV autorisées (jamais commité)
# SMARTTHINGS_TV_COMMAND_ALLOWLIST : commandes autorisées (séparées par virgule)
SMARTTHINGS_TV_COMMANDS_ENABLED=false
SMARTTHINGS_TV_COMMANDS_REQUIRE_CONFIRMATION=true
SMARTTHINGS_TV_CONFIRMATION_CODE=CONFIRMER_TV
SMARTTHINGS_TV_DEVICE_ALLOWLIST=
SMARTTHINGS_TV_COMMAND_ALLOWLIST=switch.on,switch.off,mediaPlayback.play,mediaPlayback.pause,mediaPlayback.stop
SMARTTHINGS_TV_AUDIT_ENABLED=true
SMARTTHINGS_TV_AUDIT_PATH=runtime/smartthings-tv-audit.json
SMARTTHINGS_TV_BLOCK_VOLUME_COMMANDS=true
SMARTTHINGS_TV_BLOCK_KEYPAD_INPUT=true
SMARTTHINGS_TV_BLOCK_SOURCE_CHANGE=true

# ── Streaming assisté DLNA (Phase 11) ───────────────────────────
# Streaming global désactivé par défaut — opt-in explicite requis
# MEDIA_STREAMING_ALLOWED_DIR : seul ce dossier sera scanné (jamais le disque entier)
# Ne jamais mettre un chemin contenant AppData, .ssh, System32, /etc, /proc
# DLNA_STREAMING_ENABLED : active les fonctions de lecture assistée
# DLNA_RENDERER_ALLOWLIST : IDs des renderers DLNA autorisés (séparés par virgule)
# DLNA_BLOCK_AUTOPLAY_IN_SCENARIOS=true obligatoire — jamais false
MEDIA_STREAMING_ENABLED=false
MEDIA_STREAMING_REQUIRE_CONFIRMATION=true
MEDIA_STREAMING_CONFIRMATION_CODE=CONFIRMER_STREAM
MEDIA_STREAMING_ALLOWED_DIR=
MEDIA_STREAMING_ALLOWED_EXTENSIONS=.mp4,.mkv,.mp3,.jpg,.jpeg,.png
MEDIA_STREAMING_MAX_FILE_MB=500
MEDIA_STREAMING_MASK_PATHS=true
MEDIA_STREAMING_AUDIT_ENABLED=true
MEDIA_STREAMING_AUDIT_PATH=runtime/media-streaming-audit.json
DLNA_STREAMING_ENABLED=false
DLNA_RENDERER_ALLOWLIST=
DLNA_STREAMING_TIMEOUT_MS=5000
DLNA_BLOCK_AUTOPLAY_IN_SCENARIOS=true

# ── Notifications locales (Phase 12) ────────────────────────────
# Centre de notifications interne — aucun push cloud, Firebase, email, SMS
# NOTIFICATIONS_BROWSER_ENABLED=false obligatoire par défaut
# Les données sensibles sont masquées automatiquement
# Déduplication anti-spam : 30 secondes par défaut
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_BROWSER_ENABLED=false
NOTIFICATIONS_AUDIT_ENABLED=true
NOTIFICATIONS_STORE_PATH=runtime/notifications.json
NOTIFICATIONS_MAX_ITEMS=200
NOTIFICATIONS_MASK_SENSITIVE_DATA=true
NOTIFICATIONS_DEFAULT_LEVEL=info
NOTIFICATIONS_DEDUP_WINDOW_MS=30000
NOTIFICATIONS_AUTO_CLEANUP_DAYS=30

# ── Tâches planifiées (Phase 13) ────────────────────────────────
# Moteur de scheduling local — aucun cron système, aucun cloud, aucun push externe
# Seules les actions read-only sont autorisées par défaut
# SCHEDULER_ALLOW_SENSITIVE_ACTIONS : garder false obligatoirement
# SCHEDULER_TICK_MS : intervalle de vérification interne (min 10 000)
# SCHEDULER_DEFAULT_TIMEZONE : fuseau horaire pour les tâches daily/weekly
SCHEDULER_ENABLED=true
SCHEDULER_TICK_MS=30000
SCHEDULER_STORE_PATH=runtime/schedules.json
SCHEDULER_HISTORY_PATH=runtime/schedule-history.json
SCHEDULER_MAX_HISTORY=200
SCHEDULER_NOTIFY_ON_SUCCESS=true
SCHEDULER_NOTIFY_ON_FAILURE=true
SCHEDULER_ALLOW_SENSITIVE_ACTIONS=false
SCHEDULER_DEFAULT_TIMEZONE=Europe/Paris
SCHEDULER_AUTO_START=true

# ── Scénarios intelligents (Phase 5) ────────────────────────────
# SCENARIO_LIVE_ENABLED : activer seulement si vous comprenez les risques
# SCENARIO_HISTORY_ENABLED : conserver l'historique local des exécutions
SCENARIO_LIVE_ENABLED=false
SCENARIO_HISTORY_ENABLED=true

# ── Snapshots d'observabilité (Phase 18B) ────────────────────────
# Historique compact des états système — résumés non sensibles uniquement
# OBSERVABILITY_SNAPSHOTS_ENABLED : activer/désactiver l'historique
# OBSERVABILITY_SNAPSHOTS_PATH : fichier de stockage local (runtime/)
# OBSERVABILITY_SNAPSHOTS_MAX_ITEMS : limite d'historique (défaut 200)
# OBSERVABILITY_SNAPSHOTS_NOTIFY_ON_WARNING : notification si warning
# OBSERVABILITY_SNAPSHOTS_NOTIFY_ON_ERROR : notification si error
# OBSERVABILITY_SNAPSHOTS_AUTO_CREATE_ON_START : snapshot au démarrage (false par défaut)
OBSERVABILITY_SNAPSHOTS_ENABLED=true
OBSERVABILITY_SNAPSHOTS_PATH=runtime/observability-snapshots.json
OBSERVABILITY_SNAPSHOTS_MAX_ITEMS=200
OBSERVABILITY_SNAPSHOTS_NOTIFY_ON_WARNING=true
OBSERVABILITY_SNAPSHOTS_NOTIFY_ON_ERROR=true
OBSERVABILITY_SNAPSHOTS_AUTO_CREATE_ON_START=false

# ── Phase 20 — Profils utilisateurs locaux ───────────────────────
PROFILES_ENABLED=true
PROFILES_STORE_PATH=runtime/user-profiles.json
PROFILES_ACTIVE_PATH=runtime/active-profile.json
PROFILES_MAX_ITEMS=10
PROFILES_ALLOW_PIN=false
PROFILES_REQUIRE_PIN_FOR_SENSITIVE_ACTIONS=false
PROFILES_MASK_PERSONAL_DATA=true
PROFILES_DEFAULT_PROFILE_ID=main
PROFILES_AUDIT_ENABLED=true
PROFILES_AUDIT_PATH=runtime/profile-audit.json

# ── Phase 21 — Sauvegarde locale sécurisée ───────────────────────
BACKUP_ENABLED=true
BACKUP_STORE_DIR=backups
BACKUP_RUNTIME_DIR=runtime
BACKUP_MAX_ITEMS=20
BACKUP_INCLUDE_RUNTIME_SAFE=true
BACKUP_INCLUDE_AUDITS=false
BACKUP_INCLUDE_LOGS=false
BACKUP_INCLUDE_DIST=false
BACKUP_REQUIRE_CONFIRMATION=true
BACKUP_CONFIRMATION_CODE=CONFIRMER_BACKUP
BACKUP_RESTORE_DRY_RUN_REQUIRED=true
BACKUP_ROLLBACK_ENABLED=true
BACKUP_MASK_PATHS=true
BACKUP_AUDIT_PATH=runtime/backup-audit.json

# ── Phase 45 — IA locale (Ollama) ───────────────────────────────────
# IA desactivee par defaut — activer uniquement si Ollama est installe
# SALLON_AI_ENABLED=false : pas d'appel IA, fallback gracieux
# SALLON_AI_PROVIDER=ollama : seul provider supporte (local uniquement)
# SALLON_OLLAMA_URL : doit etre localhost ou 127.0.0.1 (toute autre URL est bloquee)
# SALLON_OLLAMA_MODEL : modele a utiliser (ex: qwen2.5:7b, mistral, llama3.2)
# SALLON_AI_TIMEOUT_MS : timeout pour les requetes Ollama (30s par defaut)
# SALLON_AI_MAX_INPUT_CHARS : limite de taille des prompts (12000 par defaut)
# Installation Ollama : https://ollama.com  (puis : ollama pull qwen2.5:7b)
SALLON_AI_ENABLED=false
SALLON_AI_PROVIDER=ollama
SALLON_OLLAMA_URL=http://127.0.0.1:11434
SALLON_OLLAMA_MODEL=qwen2.5:7b
SALLON_AI_TIMEOUT_MS=30000
SALLON_AI_MAX_INPUT_CHARS=12000

# ── Phase 46 — RAG local sécurisé ───────────────────────────────────────────
# RAG desactive par defaut — activer apres indexation de la documentation
# SALLON_RAG_EMBEDDING_MODEL : modele Ollama pour les embeddings vectoriels
#   (ex: nomic-embed-text) — doit etre pull via : ollama pull nomic-embed-text
#   Fallback lexical automatique si le modele est indisponible
# SALLON_RAG_CHUNK_SIZE : taille max d'un chunk en caracteres (1200 par defaut)
# SALLON_RAG_CHUNK_OVERLAP : chevauchement entre chunks (150 par defaut)
# SALLON_RAG_MAX_FILE_SIZE_MB : taille max d'un fichier indexable (2 Mo par defaut)
# SALLON_RAG_TOP_K : nombre de chunks retrouves par recherche (5 par defaut)
# Index stocke dans runtime/rag/ (exclu de Git et des backups ZIP)
SALLON_RAG_ENABLED=false
SALLON_RAG_EMBEDDING_MODEL=nomic-embed-text
SALLON_RAG_CHUNK_SIZE=1200
SALLON_RAG_CHUNK_OVERLAP=150
SALLON_RAG_MAX_FILE_SIZE_MB=2
SALLON_RAG_TOP_K=5

# ── Phase 47 — Agents IA locaux orchestres ──────────────────────────────────
# Agents desactives par defaut — necessite SALLON_AI_ENABLED=true et Ollama
# SALLON_AGENTS_ENABLED=true : active les endpoints /api/ai/agents
# SALLON_AGENTS_MAX_STEPS : nombre max d'agents par run (defaut 6)
# SALLON_AGENTS_TIMEOUT_MS : timeout par agent en millisecondes (defaut 45000)
# SALLON_AGENTS_MEMORY_ENABLED : persistance des runs dans runtime/agents/
# SALLON_AGENTS_DRY_RUN_DEFAULT : dry-run force (ne pas mettre false)
SALLON_AGENTS_ENABLED=false
SALLON_AGENTS_MAX_STEPS=6
SALLON_AGENTS_TIMEOUT_MS=45000
SALLON_AGENTS_MEMORY_ENABLED=true
SALLON_AGENTS_DRY_RUN_DEFAULT=true

# ── Phase 48 — Workflows IA visuels locaux ───────────────────────────────────
# Workflows desactives par defaut — necessite SALLON_AI_ENABLED=true et Ollama
# SALLON_WORKFLOWS_ENABLED=true : active les endpoints /api/ai/workflows
# SALLON_WORKFLOWS_DRY_RUN_DEFAULT : dry-run force sur tous les runs (ne pas mettre false)
# SALLON_WORKFLOWS_MAX_NODES : nombre max de noeuds par workflow (defaut 25)
# SALLON_WORKFLOWS_MAX_STEPS : nombre max d'etapes d'execution par run (defaut 30)
# SALLON_WORKFLOWS_TIMEOUT_MS : timeout global par workflow en millisecondes (defaut 120000)
# SALLON_WORKFLOWS_SCHEDULER_ENABLED : scheduler automatique — laisser false en production
SALLON_WORKFLOWS_ENABLED=false
SALLON_WORKFLOWS_DRY_RUN_DEFAULT=true
SALLON_WORKFLOWS_MAX_NODES=25
SALLON_WORKFLOWS_MAX_STEPS=30
SALLON_WORKFLOWS_TIMEOUT_MS=120000
SALLON_WORKFLOWS_SCHEDULER_ENABLED=false

# ── Phase 49 — Memoire persistante IA locale ─────────────────────────────────
# Memoire desactivee par defaut — aucune donnee cloud, stockage local uniquement
# SALLON_AI_MEMORY_ENABLED=true : active les endpoints /api/ai/memory
# SALLON_AI_MEMORY_MAX_ITEMS : nombre max d'items (defaut 1000)
# SALLON_AI_MEMORY_MAX_ITEM_CHARS : taille max d'un item en caracteres (defaut 4000)
# SALLON_AI_MEMORY_EMBEDDINGS_ENABLED : embeddings Ollama pour recherche semantique
# SALLON_AI_MEMORY_RETENTION_DAYS : duree de retention en jours (defaut 90)
# SALLON_AI_MEMORY_INCLUDE_IN_RAG : inclure la memoire comme source RAG
SALLON_AI_MEMORY_ENABLED=false
SALLON_AI_MEMORY_MAX_ITEMS=1000
SALLON_AI_MEMORY_MAX_ITEM_CHARS=4000
SALLON_AI_MEMORY_EMBEDDINGS_ENABLED=false
SALLON_AI_MEMORY_RETENTION_DAYS=90
SALLON_AI_MEMORY_INCLUDE_IN_RAG=false

# ── Phase 50 — Base de connaissances locale ──────────────────────
# SALLON_KNOWLEDGE_ENABLED=true : active les endpoints /api/ai/knowledge
# SALLON_KNOWLEDGE_EMBEDDINGS_ENABLED : embeddings Ollama pour recherche semantique
# SALLON_KNOWLEDGE_MAX_ITEMS : nombre max d'items (defaut 10000)
# SALLON_KNOWLEDGE_TOP_K : nombre de resultats par defaut (defaut 8)
SALLON_KNOWLEDGE_ENABLED=false
SALLON_KNOWLEDGE_EMBEDDINGS_ENABLED=false
SALLON_KNOWLEDGE_MAX_ITEMS=10000
SALLON_KNOWLEDGE_TOP_K=8

# ── Phase 51 — Recherche globale + Command Center ─────────────────
# SALLON_SEARCH_ENABLED=true : active les endpoints /api/search
# SALLON_COMMAND_CENTER_ENABLED=true : active le command center frontend
# SALLON_SEARCH_HISTORY_MAX : nombre max d'entrees dans l'historique (defaut 50)
# SALLON_SEARCH_TOP_K : nombre de resultats par defaut (defaut 10)
SALLON_SEARCH_ENABLED=true
SALLON_COMMAND_CENTER_ENABLED=true
SALLON_SEARCH_HISTORY_MAX=50
SALLON_SEARCH_TOP_K=10

# ── Phase 52 — Profils utilisateur locaux et workspaces ───────────
# Workspaces locaux actives par defaut. Aucun cloud, stockage sous runtime/workspaces/.
# Le workspace default reste compatible avec les donnees runtime existantes.
SALLON_WORKSPACES_ENABLED=true
SALLON_DEFAULT_WORKSPACE=default
SALLON_WORKSPACE_MAX_COUNT=20
SALLON_WORKSPACE_ISOLATION_STRICT=true
SALLON_WORKSPACE_LEGACY_FALLBACK=true
SALLON_WORKSPACE_MIGRATION_AUTO=false
