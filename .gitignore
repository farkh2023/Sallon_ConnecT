# Données sensibles — ne jamais versionner
.env
.env.local
.env.production
*.key
*.pem
*.p12
*.crt
secrets.json
config.local.json

frontend/.env.local
frontend/.next/
frontend/node_modules/

# Dépendances
node_modules/
.pnp
.pnp.js

# Build
dist/*
dist/*.zip
!dist/.gitkeep
build/
.next/
out/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
npm-debug.log*
logs/*.log
logs/*.txt
!logs/.gitkeep

# Données personnelles (Phase 3+)
devices.local.json
network-scan-results.json

# Runtime local - ne pas versionner les historiques et audits
runtime/*.json
!runtime/.gitkeep
tests/.runtime/*
!tests/.runtime/.gitkeep

logs/*.json

# Prompts de travail locaux - non destines au depot public
prompts/*.md
Prompt_*.md
Phase_*.md

# Sauvegardes locales — ne pas versionner
backups/*.zip
backups/*.json
!backups/.gitkeep
runtime/backup-audit.json
